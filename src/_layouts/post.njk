---
layout: base
---

{% block head %}
{% set keywordTags = tags | without('posts') %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ site.url }}{{ page.url }}" },
  "headline": "{{ title }}",
  "description": "{{ excerpt or site.description }}",
  "image": "{{ image or site.defaultImage or site.favicon }}",
  "author": {
    "@type": "Person",
    "name": "{{ author or site.author.name }}",
    "url": "{{ site.url }}/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.logo }}"
    }
  },
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ (dateModified or date) | isoDate }}",
  "inLanguage": "en-US"{% if keywordTags.length %},
  "keywords": "{{ keywordTags | join(', ') }}"{% endif %}
}
</script>
{% endblock %}

<article class="post-article" data-slug="{{ page.fileSlug }}">
  <header class="post-header">
    <div class="container">
      <h1>{{ title }}</h1>
      <p class="post-meta">
        <span class="author">By {{ author or site.author.name }}</span>
        <span class="separator">·</span>
        <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
        <span class="separator">·</span>
        <span class="reading-time">{{ content | readingTime }} min read</span>
      </p>
    </div>
  </header>

  <div class="post-content">{{ content | safe }}</div>

  {% set relatedPosts = collections.posts | relatedPosts(page.url, tags, 4) %}
  {% if relatedPosts.length %}
  <aside class="related-posts">
    <h3>Keep Reading</h3>
    <div class="related-posts-grid">
      {% for post in relatedPosts %}
      <a href="{{ post.url }}" class="related-post-card">
        <h4>{{ post.data.title }}</h4>
        <p class="meta">{{ post.date | readableDate }}</p>
      </a>
      {% endfor %}
    </div>
  </aside>
  {% endif %}

  {% if tags %}
  <div class="post-tags">
    <div class="container">
      {% for tag in tags %}{% if tag != 'posts' %}<span class="tag">#{{ tag }}</span>{% endif %}{% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="share-buttons">
    <button class="share-btn twitter" onclick="shareOnTwitter('{{ site.url }}{{ page.url }}', '{{ title }}')">Share on X</button>
    <button class="share-btn facebook" onclick="shareOnFacebook('{{ site.url }}{{ page.url }}')">Share on Facebook</button>
    <button class="share-btn copy" onclick="copyLink('{{ site.url }}{{ page.url }}')">Copy Link</button>
  </div>

  <div class="like-section">
    <button class="like-btn" onclick="toggleLike('{{ page.fileSlug }}')">♥ Like this post</button>
    <p class="like-count">Loading...</p>
  </div>
</article>

{% block scripts %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slug = '{{ page.fileSlug }}';
    loadLikeCount(slug);
  });
</script>
{% endblock %}
